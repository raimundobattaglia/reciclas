{
  "expo": {
    "name": "RecicLas",
    "slug": "app-reciclaje",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reciclas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cl.reciclas.app",
      "infoPlist": {
        "NSCameraUsageDescription": "RecicLas necesita acceso a la cámara para escanear códigos de barra de productos y reconocer símbolos de reciclaje.",
        "NSLocationWhenInUseUsageDescription": "RecicLas usa tu ubicación para mostrarte los puntos limpios más cercanos."
      }
    },
    "android": {
      "package": "cl.reciclas.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "RecicLas necesita acceso a la cámara para escanear códigos de barra."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RecicLas usa tu ubicación para mostrarte los puntos limpios más cercanos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
